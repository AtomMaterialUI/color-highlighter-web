{
  "manifest_version": 3,
  "name": "GitHub Colorize",
  "version": "0.1.0",
  "description": "Colorize hex codes, RGB, HSL, and color names in online code editors",
  "author": "Your Name",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://github.com/*",
    "https://gitlab.com/*",
    "https://gitee.com/*",
    "https://bitbucket.org/*",
    "https://dev.azure.com/*",
    "https://*.github.dev/*",
    "https://*.gitpod.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://gitlab.com/*",
        "https://gitee.com/*",
        "https://bitbucket.org/*",
        "https://dev.azure.com/*",
        "https://*.github.dev/*",
        "https://*.gitpod.io/*"
      ],
      "js": ["content.js"],
      "css": ["styles/global.css"]
    }
  ]
}
