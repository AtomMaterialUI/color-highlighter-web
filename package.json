{
  "name": "github-colorize",
  "displayName": "GitHub Colorize",
  "version": "0.1.0",
  "description": "Colorize hex codes, RGB, HSL, and color names in online code editors",
  "author": "Your Name",
  "scripts": {
    "dev": "plasmo dev",
    "build": "bash build.sh",
    "package": "bash build.sh && zip -r github-colorize.zip build/",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx ."
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "chroma-js": "^3.2.0",
    "polished": "^4.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/chroma-js": "^3.1.2",
    "@types/chrome": "^0.2.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "eslint": "^10.6.0",
    "plasmo": "latest",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "manifest": {
    "permissions": [
      "scripting",
      "storage"
    ],
    "host_permissions": [
      "https://github.com/*",
      "https://gitlab.com/*",
      "https://gitee.com/*",
      "https://bitbucket.org/*",
      "https://dev.azure.com/*"
    ]
  }
}
