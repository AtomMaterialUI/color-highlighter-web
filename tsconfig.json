{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "types": ["chrome", "webextension-polyfill"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "~utils/*": ["./src/utils/*"],
      "~styles/*": ["./src/styles/*"]
    },
    "outDir": "./build",
    "rootDir": "./src"
  },
  "include": [".plasmo/index.d.ts", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
